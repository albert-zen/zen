{
  "name": "@zen/zenx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node ../../scripts/clean-generated-outputs.mjs package && tsc -p tsconfig.build.json && node scripts/copy-web.mjs",
    "dev": "electron .",
    "dist": "electron-builder --publish never",
    "pack": "electron-builder --dir",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zen/framework": "0.0.0"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.zen.agent",
    "productName": "ZenX",
    "publish": null,
    "asar": true,
    "artifactName": "ZenX-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.md",
      "!node_modules/**/{test,tests,__tests__,src,source,sources,docs,doc,examples}/**",
      "!node_modules/@anthropic-ai/**",
      "!node_modules/@aws-crypto/**",
      "!node_modules/@aws-sdk/**",
      "!node_modules/@google/**",
      "!node_modules/@mistralai/**",
      "!node_modules/@opentelemetry/**",
      "!node_modules/@smithy/**",
      "!node_modules/openai/**",
      "!node_modules/gaxios/**",
      "!node_modules/google-auth-library/**",
      "!node_modules/google-logging-utils/**",
      "!node_modules/zod/**",
      "!node_modules/zod-to-json-schema/**",
      "!node_modules/json-schema-to-ts/**",
      "!node_modules/ts-algebra/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
